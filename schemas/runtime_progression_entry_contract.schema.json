{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KOZO runtime progression entry contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "architecture",
    "current_state",
    "progression_entry",
    "required_prerequisites",
    "required_evidence",
    "transition_requirements",
    "forbidden_shortcuts",
    "transition_ownership",
    "future_progression_stages",
    "non_goals"
  ],
  "properties": {
    "version": {
      "const": 0
    },
    "architecture": {
      "type": "string",
      "pattern": ".*\\S.*"
    },
    "current_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "halt_contract",
        "progression_contract",
        "final_smoke_marker",
        "terminal_behavior"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": ".*\\S.*"
        },
        "halt_contract": {
          "type": "string",
          "pattern": ".*\\S.*"
        },
        "progression_contract": {
          "type": "string",
          "pattern": ".*\\S.*"
        },
        "final_smoke_marker": {
          "type": "string",
          "pattern": ".*\\S.*"
        },
        "terminal_behavior": {
          "type": "string",
          "pattern": ".*\\S.*"
        }
      }
    },
    "progression_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "marker",
        "status",
        "emitted",
        "entry_boundary"
      ],
      "properties": {
        "marker": {
          "type": "string",
          "pattern": ".*\\S.*"
        },
        "status": {
          "type": "string",
          "enum": [
            "reserved"
          ]
        },
        "emitted": {
          "type": "boolean"
        },
        "entry_boundary": {
          "type": "string",
          "pattern": ".*\\S.*"
        }
      }
    },
    "required_prerequisites": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": ".*\\S.*"
      }
    },
    "required_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": ".*\\S.*"
      }
    },
    "transition_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": ".*\\S.*"
      }
    },
    "forbidden_shortcuts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": ".*\\S.*"
      }
    },
    "transition_ownership": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": ".*\\S.*"
      }
    },
    "future_progression_stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "stage",
          "name",
          "status"
        ],
        "properties": {
          "stage": {
            "type": "integer",
            "minimum": 0
          },
          "name": {
            "type": "string",
            "pattern": ".*\\S.*"
          },
          "status": {
            "type": "string",
            "enum": [
              "proven",
              "planned"
            ]
          }
        }
      }
    },
    "non_goals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": ".*\\S.*"
      }
    }
  }
}
