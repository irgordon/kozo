{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "KOZO runtime progression contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "architecture",
    "current_state",
    "progression_prerequisites",
    "transition_requirements",
    "forbidden_shortcuts",
    "evidence_requirements",
    "non_goals"
  ],
  "properties": {
    "version": {
      "const": 0
    },
    "architecture": {
      "type": "string",
      "pattern": ".*\\S.*"
    },
    "current_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "halt_contract",
        "progression_stages_contract",
        "final_smoke_marker",
        "terminal_behavior"
      ],
      "properties": {
        "path": {
          "type": "string",
          "pattern": ".*\\S.*"
        },
        "halt_contract": {
          "type": "string",
          "pattern": ".*\\S.*"
        },
        "progression_stages_contract": {
          "type": "string",
          "pattern": ".*\\S.*"
        },
        "final_smoke_marker": {
          "type": "string",
          "pattern": ".*\\S.*"
        },
        "terminal_behavior": {
          "type": "string",
          "pattern": ".*\\S.*"
        }
      }
    },
    "progression_prerequisites": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": ".*\\S.*"
      }
    },
    "transition_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": ".*\\S.*"
      }
    },
    "forbidden_shortcuts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": ".*\\S.*"
      }
    },
    "evidence_requirements": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": ".*\\S.*"
      }
    },
    "non_goals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": ".*\\S.*"
      }
    }
  }
}
